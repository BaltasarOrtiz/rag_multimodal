# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Env — never version files containing real secrets
.env
.env.*
!.env.example

# Data & Storage (do not version documents or vectors)
backend/data/*
!backend/data/.gitkeep
backend/storage/*
!backend/storage/.gitkeep
qdrant_storage/

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.env.local

# Logs y outputs en runtime
*.log
backend/feedback.jsonl
backend/eval_results*.json
backend/.collections_meta.json

# Tests y cobertura
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db
Thumbs.db:encryptable
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
