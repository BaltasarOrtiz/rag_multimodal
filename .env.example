# ──────────────────────────────────────────────────────────────
# RAG Multimodal — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────────────────────

# Google AI Studio API Key  [REQUERIDA]
# Obtén tu key en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Colección y dimensiones de embeddings
COLLECTION_NAME=facultad_rag
EMBEDDING_DIM=3072

# Puerto del backend
API_PORT=8000

# Límite de tamaño de archivo en MB (default: 50)
MAX_UPLOAD_MB=50

# (Opcional) API Key para proteger los endpoints de la API.
# Si se configura, todos los requests deben incluir:
# Authorization: Bearer <API_KEY>
# Dejar vacío para deshabilitar la autenticación.
API_KEY=

# ── Feature flags del pipeline RAG ─────────────────────────
# Búsqueda híbrida dense+sparse (BM25) — requiere fastembed
ENABLE_HYBRID=true
# Cross-encoder reranker local
ENABLE_RERANKER=true
# HyDE (Hypothetical Document Embeddings)
ENABLE_HYDE=false
