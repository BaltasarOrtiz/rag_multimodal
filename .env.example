# ──────────────────────────────────────────────────────────────
# RAG Multimodal — Environment Variables
# Copy this file as .env and fill in the real values.
# NEVER commit .env to the repository.
# ──────────────────────────────────────────────────────────────

# Google AI Studio API Key  [REQUIRED]
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Collection name and embedding dimensions
COLLECTION_NAME=facultad_rag
EMBEDDING_DIM=3072

# Backend port
API_PORT=8000

# File size limit in MB (default: 50)
MAX_UPLOAD_MB=50

# (Optional) API Key to protect the API endpoints.
# If set, all requests must include:
# Authorization: Bearer <API_KEY>
# Leave empty to disable authentication.
API_KEY=

# ── RAG pipeline feature flags ─────────────────────────────
# Hybrid dense+sparse search (BM25) — requires fastembed
ENABLE_HYBRID=true
# Local cross-encoder reranker
ENABLE_RERANKER=true
# HyDE (Hypothetical Document Embeddings)
ENABLE_HYDE=false
